# backup - Create timestamped backup of file or directory
# Usage: backup [-c|--compress] [-d|--delete-original] <file|directory> [destination]
# Options:
#   -c, --compress       Create compressed archive using best available compression
#                        Priority: zstd > xz > bzip2 > gzip
#   -d, --delete-original  After a successful backup, remove the source path
# Examples:
#   backup myfile.txt                         → myfile.txt.20231130_123456.bak
#   backup -c mydir/                          → mydir.20231130_123456.tar.zst
#   backup -d myfile.txt                      → backup then delete myfile.txt
#   backup mydir/ /backups/mydir.bak          → creates /backups if needed

backup() {
    # Load colors if not already loaded
    [[ -z "${fg[green]:-}" ]] && autoload -U colors && colors

    local compress=false delete_original=false src dest timestamp comp_method comp_ext comp_flag
    local explicit_dest=false backup_failed=1

    # Parse options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -c|--compress)
                compress=true
                shift
                ;;
            -d|--delete-original)
                delete_original=true
                shift
                ;;
            -*)
                echo "$fg[red][X]$reset_color Unknown option: $1" >&2
                echo "Usage: backup [-c|--compress] [-d|--delete-original] <file|directory> [destination]" >&2
                return 1
                ;;
            *)
                break
                ;;
        esac
    done

    if [[ $# -eq 0 ]]; then
        echo "Usage: backup [-c|--compress] [-d|--delete-original] <file|directory> [destination]" >&2
        echo "Options:" >&2
        echo "  -c, --compress          Create compressed archive (auto-detects best method)" >&2
        echo "  -d, --delete-original   Remove source after a successful backup" >&2
        return 1
    fi

    src="$1"
    timestamp=$(date +%Y%m%d_%H%M%S)

    if [[ ! -e "$src" ]]; then
        echo "$fg[red][X]$reset_color '$src' does not exist" >&2
        return 1
    fi

    # Detect best available compression method
    if $compress; then
        if command -v zstd &>/dev/null; then
            comp_method="zstd"
            comp_ext="tar.zst"
            comp_flag="--zstd"
        elif command -v xz &>/dev/null; then
            comp_method="xz"
            comp_ext="tar.xz"
            comp_flag="-J"
        elif command -v bzip2 &>/dev/null; then
            comp_method="bzip2"
            comp_ext="tar.bz2"
            comp_flag="-j"
        elif command -v gzip &>/dev/null; then
            comp_method="gzip"
            comp_ext="tar.gz"
            comp_flag="-z"
        else
            echo "$fg[red][X]$reset_color No compression tools found (zstd, xz, bzip2, or gzip required)" >&2
            return 1
        fi
    fi

    # Determine destination
    if [[ -n "$2" ]]; then
        dest="$2"
        explicit_dest=true
    elif $compress; then
        dest="${src%/}.${timestamp}.${comp_ext}"
    else
        dest="${src%/}.${timestamp}.bak"
    fi

    if $explicit_dest; then
        if ! mkdir -p -- "$(dirname -- "$dest")"; then
            echo "$fg[red][X]$reset_color Could not create parent directory for '$dest'" >&2
            return 1
        fi
    fi

    # Check if destination exists
    if [[ -e "$dest" ]]; then
        echo "$fg[yellow][!]$reset_color '$dest' already exists" >&2
        read -q "REPLY?Overwrite? (y/n) "
        echo
        [[ $REPLY != "y" ]] && return 1
    fi

    # Perform backup
    if $compress; then
        echo "$fg[blue][i]$reset_color Backing up: $src → $dest (using $comp_method)"
        if tar "$comp_flag" -cf "$dest" -C "$(dirname "$src")" "$(basename "$src")"; then
            backup_failed=0
            echo "$fg[green]Compressed backup complete: $dest$reset_color"
            du -sh "$dest"
        else
            echo "$fg[red][X]$reset_color Backup failed" >&2
        fi
    else
        echo "$fg[blue][i]$reset_color Backing up: $src → $dest"
        if rsync -a --info=progress2 "$src" "$dest"; then
            backup_failed=0
            echo "$fg[green]Backup complete: $dest$reset_color"
            du -sh "$dest"
        else
            echo "$fg[red][X]$reset_color Backup failed" >&2
        fi
    fi

    if (( backup_failed )); then
        return 1
    fi

    if $delete_original; then
        if command rm -rf -- "$src"; then
            echo "$fg[green]Removed original: $src$reset_color"
        else
            echo "$fg[red][X]$reset_color Backup succeeded but failed to remove '$src'" >&2
            return 1
        fi
    fi
}
