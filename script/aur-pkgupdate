#!/bin/bash

# Standards integration
STANDARDS_DIR="${STANDARDS_DIR:-/home/cupric/dev/standards}"
if [[ -f "$STANDARDS_DIR/bash/standard_prompt.sh" ]]; then
    source "$STANDARDS_DIR/bash/standard_prompt.sh"
else
    # Embedded fallback
    log() {
        local level=$1; shift
        case "$level" in
            success) echo -e "\033[32m✓\033[0m $*" ;;
            error)   echo -e "\033[31m✗\033[0m $*" >&2 ;;
            warning) echo -e "\033[33m!\033[0m $*" ;;
            info)    echo -e "\033[34m→\033[0m $*" ;;
            *)       echo "$*" ;;
        esac
    }
    color_green() { echo -ne "\033[32m$1\033[0m"; }
    prompt_yn() {
        echo -n "$1 ($(color_green Y)/n): "; read -r REPLY
        [[ "$REPLY" =~ ^[nN] ]] && return 1 || return 0
    }
fi

# Function to display help information
show_help() {
    echo "Usage: $0 [-d | --dry-run] [--no-clean] [new_version]"
    echo
    echo "Options:"
    echo "  -d, --dry-run  Perform a dry run without committing changes."
    echo "  --no-clean      Skip cleaning existing src/ and pkg/ directories before building."
    echo "  new_version     Specify the new version to set in the PKGBUILD."
    echo "                  If not provided, the dynamic version from PKGBUILD will be used."
    echo "  --help          Display this help message."
    exit 0
}

# Function to check if a file exists and is readable
check_file() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        log error "$file not found."
        exit 1
    elif [[ ! -r "$file" ]]; then
        log error "$file is not readable."
        exit 1
    fi
}

# Function to validate the version format
validate_version() {
    local version="$1"
    if ! [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
        log error "Invalid version format. Use semantic versioning (e.g., 1.0.0)."
        exit 1
    fi
}

# Function to get the current pkgver from PKGBUILD
get_current_version() {
    check_file "PKGBUILD"
    local version
    version=$(grep -E '^pkgver=' PKGBUILD | cut -d'=' -f2 | xargs)
    if [[ -z "$version" ]]; then
        log error "pkgver not found in PKGBUILD."
        exit 1
    fi
    echo "$version"
}

# Function to update pkgver in PKGBUILD
update_pkgbuild_version() {
    local new_ver="$1"
    check_file "PKGBUILD"
    sed -i -E "s/^(pkgver\s*=\s*).*/\1$new_ver/" PKGBUILD
    # Always reset pkgrel to 1 when explicitly bumping version
    sed -i -E "s/^(pkgrel\s*=\s*).*/\11/" PKGBUILD
    log info "Updated pkgver to $new_ver and reset pkgrel to 1 in PKGBUILD"
}

# Function to run makepkg
run_makepkg() {
    if $clean_build; then
        log info "Running makepkg with -Cf..."
        if ! makepkg -Cf; then
            log error "makepkg failed."
            exit 1
        fi
    else
        log info "Running makepkg with -f..."
        if ! makepkg -f; then
            log error "makepkg failed."
            exit 1
        fi
    fi
}

# Function to generate .SRCINFO
generate_srcinfo() {
    log info "Generating .SRCINFO..."
    if ! makepkg --printsrcinfo > .SRCINFO; then
        log error "Failed to generate .SRCINFO."
        exit 1
    fi
}

# Main script logic
dry_run=false
clean_build=true

# Parse command-line options
while [[ "$#" -gt 0 ]]; do
    case $1 in
        -d|--dry-run)
            dry_run=true
            shift
            ;;
        --no-clean)
            clean_build=false
            shift
            ;;
        --help)
            show_help
            ;;
        *)
            if [[ -z "$new_ver_arg" ]]; then
                new_ver_arg="$1"
            else
                log error "Too many arguments."
                show_help
            fi
            shift
            ;;
    esac
done

if [[ -n "$new_ver_arg" ]]; then
    validate_version "$new_ver_arg"
    update_pkgbuild_version "$new_ver_arg"
fi

if prompt_yn "Run makepkg first?"; then
    run_makepkg
else
    log info "Updating version without a full build..."
    if ! makepkg -od; then
        log error "makepkg -od failed."
        exit 1
    fi
fi

# Always generate .SRCINFO to ensure it matches PKGBUILD
generate_srcinfo

# Extract the final updated version from PKGBUILD for the commit message
final_ver=$(get_current_version)
final_rel=$(grep -E '^pkgrel=' PKGBUILD | cut -d'=' -f2 | xargs)

# Show git diff if user wants to see it
if prompt_yn "Review changes with git diff?"; then
    git diff PKGBUILD .SRCINFO
fi

# Check if standards prompt menu/string are available, else fallback to read
read -p "Enter a commit message (default: 'Update to $final_ver-$final_rel'): " commit_message
commit_message=${commit_message:-"Update to $final_ver-$final_rel"}

if prompt_yn "Commit changes with version '$final_ver-$final_rel'?"; then
    if $dry_run; then
        log info "Dry run: Changes would be committed with version '$final_ver-$final_rel'."
        log info "Files to be added: PKGBUILD, .SRCINFO"
        log info "Commit message: $commit_message"
    else
        git add PKGBUILD .SRCINFO
        if git commit -m "$commit_message"; then
            log success "Changes committed to git."
        else
            log error "Git commit failed."
            exit 1
        fi
    fi
else
    log info "Commit aborted."
fi
